# 设置你喜欢的数据库密码
# 反正在设置了之后你这辈子也可能不会改它,输入一串别人猜不到的乱码吧
DB_PASSWORD=CHANGE_ME

# 数据库连接
DB_HOST=db
DB_PORT=5432
DB_USER=cogniloop
DB_NAME=cogniloop_db

# JWT 配置,留空会自动随机生成
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传目录
UPLOAD_DIR=./uploads

# 日志级别
LOG_LEVEL=INFO

# Redis 用于 Celery 任务队列和 SSE 跨进程广播
REDIS_URL=redis://redis:6379/0

# Fernet 加密密钥,留空会自动随机生成
ENCRYPTION_KEY=
