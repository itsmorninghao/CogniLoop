{
  "name": "cogniloop-renderer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx remotion studio src/index.tsx",
    "build:bundle": "npx remotion bundle src/index.tsx --out-dir bundle",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:bundle && npm run build:server",
    "start": "node dist/server.js",
    "render": "npx remotion render SlideVideo --props sample-props.json out.mp4"
  },
  "dependencies": {
    "@react-three/drei": "^9.115.0",
    "@react-three/fiber": "^8.17.0",
    "@remotion/bundler": "^4.0.250",
    "@remotion/cli": "^4.0.250",
    "@remotion/lottie": "^4.0.250",
    "@remotion/paths": "^4.0.250",
    "@remotion/renderer": "^4.0.250",
    "@remotion/shapes": "^4.0.250",
    "@remotion/three": "^4.0.250",
    "@remotion/transitions": "^4.0.250",
    "lottie-web": "^5.12.0",
    "express": "^4.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.250",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/three": "^0.170.0",
    "typescript": "^5.7.0"
  }
}
